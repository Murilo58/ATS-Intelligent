    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "Cadastro Removido",
        "message": "=<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Cadastro Removido</title>\n</head>\n<body style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:30px 0;\">\n<tr>\n<td align=\"center\">\n\n<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 15px rgba(0,0,0,.08);\">\n\n<tr>\n<td style=\"background:linear-gradient(90deg,#2563eb,#7c3aed);padding:28px;text-align:center;\">\n<h1 style=\"margin:0;color:#ffffff;font-size:26px;\">\nATS Inteligente\n</h1>\n<p style=\"margin-top:8px;color:#e5e7eb;font-size:15px;\">\nConfirmação de Exclusão de Cadastro\n</p>\n</td>\n</tr>\n\n<tr>\n<td style=\"padding:35px;\">\n\n<p style=\"font-size:16px;color:#1f2937;\">\nOlá, <strong>{{ $json.nome }}</strong>,\n</p>\n\n<p style=\"font-size:15px;color:#4b5563;line-height:1.8;\">\nRecebemos sua solicitação e informamos que o cadastro associado ao e-mail\n<strong>{{ $json.email }}</strong> foi removido com sucesso da base de dados do\n<strong>ATS Inteligente</strong>.\n</p>\n\n<p style=\"font-size:15px;color:#4b5563;line-height:1.8;\">\nA partir deste momento, seus dados pessoais não serão mais utilizados em nossos\nprocessos de análise de currículos e recrutamento.\n</p>\n\n<div style=\"background:#eef6ff;border-left:5px solid #2563eb;padding:18px;border-radius:6px;margin:30px 0;\">\n<p style=\"margin:0;color:#1f2937;font-size:14px;\">\nCaso deseje utilizar novamente a plataforma futuramente, será necessário realizar um novo cadastro e enviar um novo currículo para análise.\n</p>\n</div>\n\n<p style=\"font-size:15px;color:#4b5563;\">\nAgradecemos pela confiança em nossa plataforma.\n</p>\n\n<p style=\"margin-top:35px;color:#1f2937;\">\nAtenciosamente,<br>\n<strong>Equipe ATS Inteligente</strong><br>\nOrizon AI & Projects\n</p>\n\n</td>\n</tr>\n\n<tr>\n<td style=\"background:#0f172a;padding:18px;text-align:center;color:#94a3b8;font-size:12px;\">\nEste e-mail foi enviado automaticamente pelo ATS Inteligente.<br><br>\n© 2026 ATS Inteligente • Orizon AI & Projects\n</td>\n</tr>\n\n</table>\n\n</td>\n</tr>\n</table>\n\n</body>\n</html>",
        "options": {}
