    {
      "parameters": {
        "jsCode": "const raw = $json.output || '';\n\nconst clean = raw\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\nlet dados;\n\ntry {\n  dados = JSON.parse(clean);\n} catch (error) {\n  dados = {\n    assunto_email: 'Solicitação Recebida - ATS Inteligente',\n    titulo: 'Solicitação Recebida',\n    subtitulo: 'Atendimento ATS Inteligente',\n    mensagem: 'Recebemos sua mensagem e ela será analisada pela nossa equipe.'\n  };\n}\n\nconst nome = $('mapear_categoria').item.json.body?.nome || 'Olá';\nconst email = $('mapear_categoria').item.json.body?.email || '';\nconst categoria = $('mapear_categoria').item.json.Categoria || 'outro';\n\nconst cores = {\n  informacao: '#2563EB',\n  proposta: '#7C3AED',\n  suporte: '#F59E0B',\n  exclusao_dados: '#DC2626',\n  outro: '#475569',\n  other: '#475569'\n};\n\nconst labels = {\n  informacao: 'INFORMAÇÃO',\n  proposta: 'PROPOSTA COMERCIAL',\n  suporte: 'SUPORTE',\n  exclusao_dados: 'EXCLUSÃO DE DADOS',\n  outro: 'CONTATO',\n  other: 'CONTATO'\n};\n\nconst cor = cores[categoria] || '#475569';\nconst label = labels[categoria] || 'CONTATO';\n\nconst html_email = `\n<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>${dados.assunto_email}</title>\n</head>\n<body style=\"margin:0;padding:0;background:#eef2f7;font-family:Arial,Helvetica,sans-serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#eef2f7;padding:32px 0;\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"650\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:18px;overflow:hidden;box-shadow:0 10px 30px rgba(15,23,42,0.12);\">\n          \n          <tr>\n            <td align=\"center\" style=\"padding:42px 32px;background:linear-gradient(135deg,#2563EB,#7C3AED);\">\n              <div style=\"font-size:34px;line-height:1.2;color:#ffffff;font-weight:bold;\">\n                ATS Inteligente\n              </div>\n              <div style=\"margin-top:10px;font-size:16px;line-height:1.5;color:#e0e7ff;\">\n                Plataforma Inteligente para Gestão de Talentos\n              </div>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"padding:38px 42px;\">\n              <div style=\"display:inline-block;padding:8px 16px;border-radius:999px;background:${cor};color:#ffffff;font-size:12px;font-weight:bold;letter-spacing:0.5px;\">\n                ${label}\n              </div>\n\n              <h2 style=\"margin:26px 0 8px 0;color:#0f172a;font-size:24px;line-height:1.35;\">\n                ${dados.titulo || 'Solicitação recebida'}\n              </h2>\n\n              <p style=\"margin:0 0 28px 0;color:#64748b;font-size:15px;line-height:1.6;\">\n                ${dados.subtitulo || 'Recebemos sua mensagem pelo formulário de contato.'}\n              </p>\n\n              <p style=\"margin:0 0 22px 0;color:#334155;font-size:16px;line-height:1.8;\">\n                Olá <strong>${nome}</strong>,\n              </p>\n\n              <div style=\"color:#334155;font-size:16px;line-height:1.8;margin-bottom:28px;\">\n                ${(dados.mensagem || '').replace(/\\n/g, '<br>')}\n              </div>\n\n              <div style=\"background:#f8fafc;border-left:4px solid ${cor};padding:18px 20px;border-radius:10px;margin:28px 0;\">\n                <p style=\"margin:0;color:#475569;font-size:14px;line-height:1.7;\">\n                  Esta mensagem foi registrada pelo ATS Inteligente. Caso precise complementar alguma informação, responda este e-mail.\n                </p>\n              </div>\n\n              <p style=\"margin:30px 0 0 0;color:#334155;font-size:16px;line-height:1.7;\">\n                Atenciosamente,<br>\n                <strong>Equipe ATS Inteligente</strong>\n              </p>\n            </td>\n          </tr>\n\n          <tr>\n            <td align=\"center\" style=\"background:#0f172a;padding:28px 32px;\">\n              <div style=\"color:#ffffff;font-size:17px;font-weight:bold;\">\n                Orizon AI & Projects\n              </div>\n              <div style=\"margin-top:8px;color:#cbd5e1;font-size:13px;line-height:1.6;\">\n                Automação • Inteligência Artificial • Gestão de Projetos\n              </div>\n              <div style=\"margin-top:18px;\">\n                <a href=\"https://your-domain.com\" style=\"color:#60a5fa;text-decoration:none;font-size:13px;\">\n                  your-domain.com\n                </a>\n              </div>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>\n`;\n\nreturn [\n  {\n    json: {\n      assunto_email: dados.assunto_email || 'Solicitação Recebida - ATS Inteligente',\n      html_email,\n      email_destino: email,\n      categoria\n    }\n  }\n];"
      },
